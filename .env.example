# Backend environment variables for Notification & Communication Hub
# Copy to .env and fill in secrets. Do NOT commit .env with real secrets.

# App
PORT=5004
NODE_ENV=development
APP_URL=https://schoolmangementbackend-production.up.railway.app

# CORS — set allowed frontend origins (comma-separated). Example:
# CORS_ALLOWED_ORIGINS=http://localhost:5173,https://app.example.com,regex:^https:\/\/.*\.vercel\.app$
#
# Public frontend URL used when generating links in system emails (verification, reset password).
# Set this to your deployed frontend (e.g. https://your-app.vercel.app). If unset, `CLIENT_URL` is used.
# PUBLIC_FRONTEND_URL=https://your-app.vercel.app
# In production, set this to your deployed frontend origin(s) only.

# MongoDB
MONGODB_URI=mongodb+srv://mohamedciise892_db_user:Hooyo123@schoolsystem.hnbfqei.mongodb.net/?appName=SchoolSystem
# JWT
JWT_SECRET=your_super_secret_jwt_key

# Encryption key for provider config (base64, 32 bytes for AES-256-GCM)
PROVIDER_CONFIG_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

# Redis for queues (BullMQ) and scheduler (optional)
REDIS_URL=redis://default:********@gorgeous-katydid-42803.upstash.io:6379

# Email Providers (in order of priority: Resend > SES > SMTP)
# Resend (Preferred)
RESEND_API_KEY=re_D2Q6kreQ_G4yHi3RAx4B8kZbRDvzTBx68

# AWS SES (Fallback)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# SMTP (Last Resort, Dev Only)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_smtp_user
EMAIL_PASS=your_smtp_password
EMAIL_FROM_NAME="School Name"
EMAIL_FROM="School Name" <no-reply@your-school.example>
EMAIL_REPLY_TO=support@your-school.example

# Nodemailer / SMTP (for transactional emails fallback)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your_smtp_user
# SMTP_PASS=your_smtp_password
# SMTP_FROM="School Name" <no-reply@your-school.example>

# SendGrid (preferred transactional email provider)
SENDGRID_API_KEY=
SENDGRID_FROM_NAME="School Name"
SENDGRID_FROM_EMAIL=no-reply@your-school.example

# Mailgun (optional)
MAILGUN_API_KEY=
MAILGUN_DOMAIN=

# AWS SES (optional)
# AWS_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# SES_FROM_ADDRESS=no-reply@your-school.example

# Twilio (SMS + WhatsApp via Twilio) — optional
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1234567890

# Africa's Talking (SMS)
AT_USERNAME=
AT_API_KEY=

# Somtel / Hormuud / Local SMS providers — add credentials per provider
SOMTEL_API_KEY=
SOMTEL_SENDER_ID=
HORMUUD_API_KEY=
HORMUUD_SENDER_ID=

# Meta / WhatsApp Cloud API (Meta Business) — for WhatsApp messages
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_ACCESS_TOKEN=
META_WHATSAPP_VERIFY_TOKEN=

# Firebase Cloud Messaging (FCM) for native push (Android/iOS)
FCM_SERVER_KEY=
FCM_SERVICE_ACCOUNT_JSON_PATH=./serviceAccountKey.json

# Expo Push (if using Expo push service)
EXPO_ACCESS_TOKEN=

# VAPID keys for Web Push (generate with web-push)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# SMTP bounce/webhook endpoint secret (for validating callbacks)
SMTP_WEBHOOK_SECRET=

# Webhook secret for Twilio, Africa's Talking, Meta, etc.
TWILIO_WEBHOOK_SECRET=
AT_WEBHOOK_SECRET=
META_WEBHOOK_SECRET=

# Optional: Resend (alternative email provider)
# RESEND_API_KEY=

# Default timezone for scheduled jobs
DEFAULT_TIMEZONE=UTC

# Logging / monitoring
SENTRY_DSN=

# Feature flags
ENABLE_QUEUE=true
ENABLE_SCHEDULER=true

# Example limits
MAX_SMS_BATCH_SIZE=500
MAX_WHATSAPP_BATCH_SIZE=500
# Backend Configuration
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000

