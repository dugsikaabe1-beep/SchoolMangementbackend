# Backend environment variables for Notification & Communication Hub
# Copy to .env and fill in secrets. Do NOT commit .env with real secrets.

# App
PORT=5003
NODE_ENV=development
APP_URL=http://localhost:5003

# MongoDB
MONGODB_URI=mongodb://localhost:27017/school_management

# JWT
JWT_SECRET=replace_with_a_strong_jwt_secret

# Encryption key for provider config (base64, 32 bytes for AES-256-GCM)
PROVIDER_CONFIG_KEY=replace_with_base64_32_byte_key

# Redis for queues (BullMQ) and scheduler (optional)
REDIS_URL=redis://localhost:6379

# Nodemailer / SMTP (for transactional emails fallback)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM="School Name" <no-reply@your-school.example>

# SendGrid (preferred transactional email provider)
SENDGRID_API_KEY=
SENDGRID_FROM_NAME="School Name"
SENDGRID_FROM_EMAIL=no-reply@your-school.example

# Mailgun (optional)
MAILGUN_API_KEY=
MAILGUN_DOMAIN=

# AWS SES (optional)
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SES_FROM_ADDRESS=no-reply@your-school.example

# Twilio (SMS + WhatsApp via Twilio) — optional
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1234567890

# Africa's Talking (SMS)
AT_USERNAME=
AT_API_KEY=

# Somtel / Hormuud / Local SMS providers — add credentials per provider
SOMTEL_API_KEY=
SOMTEL_SENDER_ID=
HORMUUD_API_KEY=
HORMUUD_SENDER_ID=

# Meta / WhatsApp Cloud API (Meta Business) — for WhatsApp messages
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_ACCESS_TOKEN=
META_WHATSAPP_VERIFY_TOKEN=

# Firebase Cloud Messaging (FCM) for native push (Android/iOS)
FCM_SERVER_KEY=
FCM_SERVICE_ACCOUNT_JSON_PATH=./serviceAccountKey.json

# Expo Push (if using Expo push service)
EXPO_ACCESS_TOKEN=

# VAPID keys for Web Push (generate with web-push)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# SMTP bounce/webhook endpoint secret (for validating callbacks)
SMTP_WEBHOOK_SECRET=

# Webhook secret for Twilio, Africa's Talking, Meta, etc.
TWILIO_WEBHOOK_SECRET=
AT_WEBHOOK_SECRET=
META_WEBHOOK_SECRET=

# Optional: Resend (alternative email provider)
RESEND_API_KEY=

# Default timezone for scheduled jobs
DEFAULT_TIMEZONE=UTC

# Logging / monitoring
SENTRY_DSN=

# Feature flags
ENABLE_QUEUE=true
ENABLE_SCHEDULER=true

# Example limits
MAX_SMS_BATCH_SIZE=500
MAX_WHATSAPP_BATCH_SIZE=500
# Backend Configuration
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000

