<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Segoe UI', Arial, sans-serif; color: #1e293b; font-size: 13px; padding: 32px; background: #fff; }
    .header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 28px; border-bottom: 3px solid #4f46e5; padding-bottom: 20px; }
    .school-info h1 { font-size: 22px; font-weight: 800; color: #1e293b; }
    .school-info p  { color: #64748b; font-size: 12px; margin-top: 3px; }
    .payslip-label  { text-align: right; }
    .payslip-label h2  { font-size: 20px; font-weight: 700; color: #4f46e5; }
    .payslip-label .no { font-size: 12px; color: #64748b; margin-top: 4px; }
    .info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 24px; }
    .info-box { background: #f8fafc; border-radius: 10px; padding: 14px 18px; }
    .info-box h3 { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: .1em; color: #94a3b8; margin-bottom: 8px; }
    .info-row { display: flex; justify-content: space-between; margin-bottom: 4px; }
    .info-row .label { color: #64748b; }
    .info-row .value { font-weight: 600; color: #1e293b; }
    table { width: 100%; border-collapse: collapse; margin-bottom: 20px; }
    thead tr { background: #4f46e5; color: #fff; }
    thead th { padding: 10px 14px; text-align: left; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; }
    tbody tr { border-bottom: 1px solid #e2e8f0; }
    tbody tr:nth-child(even) { background: #f8fafc; }
    tbody td { padding: 9px 14px; }
    .amount { text-align: right; font-weight: 600; }
    .green { color: #16a34a; }
    .red   { color: #dc2626; }
    .summary { background: #f1f5f9; border-radius: 12px; padding: 18px 24px; margin-bottom: 20px; }
    .summary-row { display: flex; justify-content: space-between; padding: 6px 0; border-bottom: 1px solid #e2e8f0; }
    .summary-row:last-child { border-bottom: none; }
    .summary-row.net { font-size: 16px; font-weight: 800; color: #4f46e5; margin-top: 6px; }
    .status-badge { display: inline-block; padding: 4px 12px; border-radius: 20px; font-size: 11px; font-weight: 700; text-transform: uppercase; }
    .status-Paid      { background: #dcfce7; color: #16a34a; }
    .status-Approved  { background: #ede9fe; color: #7c3aed; }
    .status-Draft     { background: #fef9c3; color: #ca8a04; }
    .footer { text-align: center; color: #94a3b8; font-size: 11px; margin-top: 24px; border-top: 1px solid #e2e8f0; padding-top: 16px; }
  </style>
</head>
<body>
  <div class="header">
    <div class="school-info">
      {{#if schoolLogo}}<img src="{{schoolLogo}}" alt="Logo" style="height:50px;margin-bottom:8px;" />{{/if}}
      <h1>{{schoolName}}</h1>
      <p>{{schoolAddress}}</p>
      <p>{{schoolPhone}}</p>
    </div>
    <div class="payslip-label">
      <h2>PAYSLIP</h2>
      <div class="no">{{payslipNumber}}</div>
      <div class="no">Period: {{period}}</div>
      <div style="margin-top:8px;"><span class="status-badge status-{{status}}">{{status}}</span></div>
    </div>
  </div>

  <div class="info-grid">
    <div class="info-box">
      <h3>Employee Details</h3>
      <div class="info-row"><span class="label">Name</span><span class="value">{{employeeName}}</span></div>
      <div class="info-row"><span class="label">Employee ID</span><span class="value">{{employeeId}}</span></div>
      <div class="info-row"><span class="label">Email</span><span class="value">{{employeeEmail}}</span></div>
    </div>
    <div class="info-box">
      <h3>Payment Details</h3>
      <div class="info-row"><span class="label">Period</span><span class="value">{{period}}</span></div>
      <div class="info-row"><span class="label">Method</span><span class="value">{{paymentMethod}}</span></div>
      <div class="info-row"><span class="label">Payment Date</span><span class="value">{{paymentDate}}</span></div>
      <div class="info-row"><span class="label">Currency</span><span class="value">{{currency}}</span></div>
    </div>
  </div>

  <!-- Earnings -->
  <table>
    <thead><tr><th>Earnings</th><th>Type</th><th class="amount">Amount ({{currency}})</th></tr></thead>
    <tbody>
      <tr><td>Basic Salary</td><td>Fixed</td><td class="amount green">{{basicSalary}}</td></tr>
      {{#each allowanceItems}}
      <tr>
        <td>{{this.name}}</td>
        <td>{{this.type}}</td>
        <td class="amount green">{{this.amount}}</td>
      </tr>
      {{/each}}
      <tr style="font-weight:700;background:#f0fdf4;">
        <td colspan="2">Gross Salary</td>
        <td class="amount green">{{grossSalary}}</td>
      </tr>
    </tbody>
  </table>

  <!-- Deductions -->
  {{#if deductionItems.length}}
  <table>
    <thead><tr><th>Deductions</th><th>Type</th><th class="amount">Amount ({{currency}})</th></tr></thead>
    <tbody>
      {{#each deductionItems}}
      <tr>
        <td>{{this.name}}</td>
        <td>{{this.type}}</td>
        <td class="amount red">{{this.amount}}</td>
      </tr>
      {{/each}}
      {{#if taxAmount}}
      <tr><td>Income Tax ({{../taxRate}}%)</td><td>Statutory</td><td class="amount red">{{taxAmount}}</td></tr>
      {{/if}}
    </tbody>
  </table>
  {{/if}}

  <!-- Summary -->
  <div class="summary">
    <div class="summary-row"><span>Gross Salary</span><span>{{currency}} {{grossSalary}}</span></div>
    <div class="summary-row red"><span>Total Deductions</span><span>- {{currency}} {{totalDeductions}}</span></div>
    <div class="summary-row net"><span>NET SALARY</span><span>{{currency}} {{netSalary}}</span></div>
  </div>

  <div class="footer">
    Generated on {{generatedAt}} · This is a computer-generated payslip and does not require a signature.
  </div>
</body>
</html>
