

# Application Environment
NODE_ENV=production
PORT=5004
APP_URL=https://schoolmangementbackend-deployment.up.railway.app/api

# Database Connection
MONGODB_URI=mongodb+srv://mohamedciise892_db_user:Hooyo123@schoolsystem.hnbfqei.mongodb.net/?appName=SchoolSystem

# JWT Authentication
JWT_SECRET=your_super_secret_jwt_key_at_least_32_characters_long

# ====================================================
# IMPORTANT - Core Features (Email, Uploads, Cache)
# ====================================================

# Redis Cache & Job Queue
REDIS_URL=redis://default:password@host:6379

# Email Configuration (SMTP)
# For Gmail: Use app-specific password
# For other providers: Use appropriate credentials
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-specific-password
EMAIL_FROM=noreply@your-school.example
EMAIL_FROM_NAME=Your School Name
EMAIL_REPLY_TO=support@your-school.example

# Cloudinary (Image & File Upload Storage)
CLOUDINARY_CLOUD_NAME=l4pof8yh
CLOUDINARY_API_KEY=253992374144996
CLOUDINARY_API_SECRET=DIYUMe4T8FdkTjUDX0zINZJb76U
CLOUDINARY_ROOT_FOLDER=dugsihub

# ====================================================
# NETWORK & SECURITY
# ====================================================

# CORS - Allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,https://schoolmangementbackend-deployment.up.railway.app,https://your-frontend-domain.com,https://app.your-domain.com,regex:^https:\/\/.*\.vercel\.app$

# Frontend URLs for generating links in emails
CLIENT_URL=https://dugsimaamul.vercel.app
PUBLIC_FRONTEND_URL=https://dugsimaamul.vercel.app

# Multi-tenant Configuration
ROOT_DOMAIN=dugsimaamul.vercel.app
TRUST_PROXY=1

# Development Only - Allow header-based tenant override
ALLOW_DEV_TENANT_HEADER=false
ALLOW_MOBILE_TENANT_HEADER=false

# ====================================================
# COMMUNICATION PROVIDERS (Optional)
# ====================================================

# Firebase Cloud Messaging (Push Notifications - iOS/Android)
FCM_SERVER_KEY=your_fcm_server_key
FCM_SERVICE_ACCOUNT_JSON_PATH=./serviceAccountKey.json

# Resend Email (Alternative email provider - optional)
RESEND_API_KEY=your_resend_api_key

# ====================================================
# FEATURE FLAGS & TUNING
# ====================================================

# Job Queue & Background Tasks
ENABLE_QUEUE=true
ENABLE_SCHEDULER=true

# Notification Scheduler
RUN_NOTIFICATION_SCHEDULER=1
NOTIFICATION_SCHEDULER_INTERVAL_MS=60000

# Email Timeouts (milliseconds)
EMAIL_CONNECTION_TIMEOUT_MS=15000
EMAIL_GREETING_TIMEOUT_MS=10000
EMAIL_SOCKET_TIMEOUT_MS=30000
EMAIL_MAX_CONNECTIONS=3
EMAIL_MAX_MESSAGES=100

# Timezone for Scheduled Jobs
DEFAULT_TIMEZONE=UTC

# ====================================================
# OPTIONAL - Security & Encryption
# ====================================================

# Encryption Key for Sensitive Data
CONFIG_ENCRYPTION_KEY=your_32_character_base64_encoded_key

# JWT Token Expiry (Optional - defaults to 24h access, 7d refresh)
JWT_ACCESS_EXPIRES=24h
JWT_REFRESH_EXPIRES=7d
JWT_REFRESH_SECRET=optional_separate_refresh_secret

# ====================================================
# NOT RECOMMENDED IN PRODUCTION
# ====================================================

# Only enable in development for testing
ALLOW_API_WITHOUT_HOST_TENANT=false

# ====================================================
# NOTES
# ====================================================
# 1. CRITICAL variables (top section) are required
# 2. IMPORTANT variables are needed for core features
# 3. Communication providers are optional - app works without them
# 4. Use strong, unique secrets in production
# 5. Never commit real secrets to version control
# 6. Use a secrets manager (AWS Secrets Manager, Vault, etc.) for production
# ====================================================

